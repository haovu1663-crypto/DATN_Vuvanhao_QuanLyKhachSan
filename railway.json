{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "./gradlew clean bootJar -x check -x test"
  },
  "deploy": {
    "startCommand": "java -jar build/libs/$(ls build/libs/ | grep '.jar' | head -1)",
    "restartPolicyType": "ON_FAILURE"
  }
}